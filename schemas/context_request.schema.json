{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "task"
  ],
  "properties": {
    "task": {
      "type": "string"
    },
    "project_name": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "max_results": {
      "type": "integer",
      "minimum": 1
    },
    "privacy_level": {
      "type": "string",
      "enum": [
        "public_example",
        "local_private",
        "sensitive"
      ]
    }
  },
  "additionalProperties": false
}

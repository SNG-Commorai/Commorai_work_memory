{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "memory_id",
    "created_at",
    "updated_at",
    "memory_type",
    "title",
    "summary",
    "content",
    "tags",
    "importance",
    "confidence",
    "source",
    "privacy_level",
    "status",
    "update_mode",
    "target_path",
    "links",
    "content_hash"
  ],
  "properties": {
    "memory_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "memory_type": {
      "type": "string",
      "enum": [
        "base_memory",
        "project_memory",
        "short_term_memory"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "content": {
      "type": "string"
    },
    "project_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "project_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "field": {
      "type": [
        "string",
        "null"
      ]
    },
    "module": {
      "type": [
        "string",
        "null"
      ]
    },
    "subtype": {
      "type": [
        "string",
        "null"
      ]
    },
    "field_or_module": {
      "type": [
        "string",
        "null"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "importance": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "confidence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "privacy_level": {
      "type": "string",
      "enum": [
        "public_example",
        "local_private",
        "sensitive"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "pending_review",
        "duplicate_skipped",
        "conflict_recorded",
        "archived"
      ]
    },
    "update_mode": {
      "type": "string",
      "enum": [
        "append",
        "conflict_only",
        "migrate",
        "noop"
      ]
    },
    "target_path": {
      "type": "string",
      "minLength": 1
    },
    "links": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "session_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "turn_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "source_event_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "content_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  },
  "additionalProperties": true
}

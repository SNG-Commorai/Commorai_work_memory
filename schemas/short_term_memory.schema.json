{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "memory_type",
    "content"
  ],
  "properties": {
    "memory_type": {
      "const": "short_term_memory"
    },
    "subtype": {
      "type": "string"
    },
    "project_name": {
      "type": "string"
    },
    "retention_days": {
      "type": "integer",
      "minimum": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "importance": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "confidence": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "privacy_level": {
      "type": "string",
      "enum": [
        "public_example",
        "local_private",
        "sensitive"
      ]
    },
    "content": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
